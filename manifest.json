{
  "manifest_version": 3,
  "name": "VOV Radio - Nghe Đài Tiếng nói Việt Nam",
  "version": "1.0.0",
  "description": "Tiện ích nghe Đài Tiếng nói Việt Nam (VOV) trực tuyến nhanh chóng, tiện lợi với giao diện cực kỳ tối giản. Hỗ trợ chạy nền mượt mà.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "offscreen"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vov-radio-minimal@ext.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
